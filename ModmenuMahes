// NOTIFICATION SYSTEM
// ==========================================
function showNotification(text, color)
    local notif = Instance.new("ScreenGui")
    notif.Name = "Notification"
    notif.Parent = CoreGui
    
    local frame = Instance.new("Frame")
    frame.Size = UDim2.new(0, 250, 0, 50)
    frame.Position = UDim2.new(0.5, -125, 0, -60)
    frame.BackgroundColor3 = color or Color3.fromRGB(0, 255, 255)
    frame.BorderSizePixel = 0
    frame.Parent = notif
    
    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, 12)
    corner.Parent = frame
    
    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(1, -20, 1, 0)
    label.Position = UDim2.new(0, 10, 0, 0)
    label.BackgroundTransparency = 1
    label.Text = text
    label.TextColor3 = Color3.fromRGB(0, 0, 0)
    label.TextSize = 14
    label.Font = Enum.Font.GothamBold
    label.Parent = frame
    
    -- Animate in
    TweenService:Create(frame, TweenInfo.new(0.5, Enum.EasingStyle.Back), {
        Position = UDim2.new(0.5, -125, 0, 20)
    }):Play()
    
    -- Animate out
    wait(3)
    TweenService:Create(frame, TweenInfo.new(0.5, Enum.EasingStyle.Quad), {
        Position = UDim2.new(0.5, -125, 0, -60)
    }):Play()
    
    wait(0.5)
    notif:Destroy()
end

