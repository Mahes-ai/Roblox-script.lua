        local flyingDown = false
        
        upBtn.InputBegan:Connect(function() flyingUp = true end)
        upBtn.InputEnded:Connect(function() flyingUp = false end)
        downBtn.InputBegan:Connect(function() flyingDown = true end)
        downBtn.InputEnded:Connect(function() flyingDown = false end)
        
        spawn(function()
            while enabled and flyGui.Parent do
                wait()
                if flyingUp then
                    hrp.Velocity = Vector3.new(0, flySpeed, 0)
