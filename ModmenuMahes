local function AntiDetection()
    -- Hook metatable to prevent detection
    local mt = getrawmetatable(game)
    local oldNamecall = mt.__namecall
    setreadonly(mt, false)
    
    mt.__namecall = newcclosure(function(self, ...)
        local method = getnamecallmethod()
        local args = {...}
        
        -- Block detection calls
        if method == "Kick" or method == "FireServer" then
            if tostring(self):lower():find("detect") or tostring(self):lower():find("ban") or tostring(self):lower():find("check") then
                return wait(9e9)
            end
        end
        
        return oldNamecall(self, ...)
    end)
    
    setreadonly(mt, true)
    
    -- Block remote events that detect cheating
    for _, v in pairs(ReplicatedStorage:GetDescendants()) do
        if v:IsA("RemoteEvent") or v:IsA("RemoteFunction") then
            if tostring(v):lower():find("detect") or tostring(v):lower():find("ban") or tostring(v):lower():find("anticheat") then
                v:Destroy()
            end
        end
    end
    
    -- Spoof memory
    if hookfunction then
        local oldHook = hookfunction
        hookfunction = function(func, replacement)
            if tostring(func):lower():find("memory") or tostring(func):lower():find("check") then
                return function() return true end
            end
            return oldHook(func, replacement)
        end
    end
end

